# Database
DATABASE_URL=postgresql+asyncpg://football_user:football_pass@postgres:5432/football_predictions

# Redis
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=change-this-to-a-random-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# External APIs (optional — mock data used if not set)
API_FOOTBALL_KEY=
FOOTBALL_DATA_KEY=

# AI Provider (for natural language match analysis)
# Supported: openai, openrouter, gemini, ollama
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_BASE_URL=
AI_MAX_TOKENS=500
AI_TEMPERATURE=0.7

# ML
ML_MODEL_PATH=/app/models

# Environment
ENVIRONMENT=development
DEBUG=true
